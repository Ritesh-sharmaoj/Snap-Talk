# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:8081
TRUST_PROXY=false

# Database Configuration
# For public deployment, use MongoDB Atlas, for example:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/snap-talk?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/snap-talk

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Media Upload (Cloudinary)
# Cloudinary is used for image/video uploads. You can still create posts by
# sending mediaUrl directly if these are not configured.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
