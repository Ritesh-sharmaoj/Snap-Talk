# API Configuration
# Local web development
EXPO_PUBLIC_API_URL=http://localhost:5002/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:5002

# Physical phone on the same Wi-Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.50:5002/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.50:5002

# APK that works from any network:
# EXPO_PUBLIC_API_URL=https://your-public-backend.example.com/api
# EXPO_PUBLIC_SOCKET_URL=https://your-public-backend.example.com
