{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://172.31.0.31:5002/api",
        "EXPO_PUBLIC_SOCKET_URL": "http://172.31.0.31:5002"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://your-public-backend.example.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://your-public-backend.example.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
